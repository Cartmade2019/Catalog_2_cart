{{ 'https://cdn.tailwindcss.com' | script_tag }}

{{ 'main.css' | asset_url | stylesheet_tag }}

{% assign pdfMetafields = shop.metafields.PDF %}

{% assign buttonHotspot = shop.metafields.cartmade.cod_button_settings %}

{% assign tooltipHotspot = shop.metafields.cartmade.cod_tooltip_settings %}

{% assign pdfMetafield = pdfMetafields[block.settings.metafield_key] %}

{% assign pdfData = pdfMetafield.value %}

{% assign buttonData = buttonHotspot.value %}

{% assign toolTipData = tooltipHotspot.value %}

{% assign array_length = pdfData.images | size %}

{% assign images = pdfData.images %}

{% comment %} Determine if wide-format mode is needed (anything other than A4) {% endcomment %}

{% assign pageFormat = pdfData.pageFormat | default: 'A4' | upcase %}

{% if pageFormat == 'A4' %}
  {% assign isWideFormat = false %}
{% else %}
  {% assign isWideFormat = true %}
{% endif %}

{% for image in images %}
  {% assign pageIndex = forloop.index | minus: 1 %}

  {% for point in image.points %}
    {% assign hotSpotIndex = forloop.index %}

    {% render 'tooltip',
      data_page_index: pageIndex,
      data_hotspot_index: hotSpotIndex,
      buttonData: buttonData,
      tooltipData: toolTipData,
      handle: point.handle
    %}
  {% endfor %}
{% endfor %}

{%- style -%}
  .section-{{ block.id }}-padding {
    padding-top: {{ block.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ block.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ block.id }}-padding {
      padding-top: {{ block.settings.padding_top }}px;
      padding-bottom: {{ block.settings.padding_bottom }}px;
    }
  }
  
  /* Fix for wide format hotspots */
  .wide-back .custom-hotspot,
  .wide-front .custom-hotspot {
    position: absolute !important;
  }

  html {
  scrollbar-gutter: stable;
}

{%- endstyle -%}

<!-- Main Flipbook Section -->

<div class="relative">
  <div class="pdf-main-container section-{{ block.id }}-padding relative" style="display:flex; justify-content:center;">
    <div class="pdf-body-wrapper">
      <!-- Book Container -->

      <div class="book-container">
        <div
          class="book{% if isWideFormat %} wide-format{% endif %}"
          data-wide-format="{{ isWideFormat }}"
          data-pdf-format="{{ pageFormat }}"
        >
          <div class="page">
            <div class="front cover">
              {% if pdfData.coverImage %}
                <img src="{{ pdfData.coverImage }}" alt="{{ pdfData.pdfName }}">
              {% else %}
                <div class="cover-title-wrap">
                  <span class="cover-title">{{ pdfData.pdfName }}</span>
                </div>
              {% endif %}
            </div>

            {% if isWideFormat %}
              <!-- Back of cover - LEFT half of image[0] -->
              <div class="back wide-back relative" style="background-image: url('{{ pdfData.images[0].url }}');">
                {% assign cover_points = pdfData.images[0].points %}
                {% for point in cover_points %}
                  {% comment %}
                    FIXED: For left pages, we need to adjust xPercentage to account for the half-page view.
                    The original xPercentage (0-100) refers to the FULL image width.
                    On left page, we only show the LEFT half (0-50% of original).
                    So we map: original xPercentage (0-50) → new x (0-100) for this half-page
                    But we DON'T mirror - the hotspot should stay on the left side where it belongs.
                  {% endcomment %}
                  {% if point.xPercentage < 50 %}
                    {% comment %} Map 0-50% to 0-100% for the left half-page {% endcomment %}
                    {% assign adjusted_left = point.xPercentage | times: 2 %}
                    
                    <div
                      data-id="hotspot-0-{{forloop.index}}"
                      class="custom-hotspot bg-[{{buttonData.hotspotColor}}] points absolute z-[999] top-[{{point.yPercentage}}%] left-[{{adjusted_left}}%] image-hotspots--pin flex justify-center items-center text-white text-sm h-9 w-9 rounded-full shadow-lg cursor-pointer animate-pulse"
                    >
                      <div class="image-hotspots--pin-button hotspot--pinned active">
                        <svg width="25" height="25" viewBox="0 0 25 25" fill="none">
                          <rect width="25" height="25" rx="12.5" stroke="#F1EFED" stroke-width="9"/>
                          <rect x="4.5" y="4.5" width="16" height="16" rx="8" fill="none" stroke="#F1EFED" stroke-width="9"/>
                        </svg>
                      </div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            {% else %}
              <div class="back relative">
                {% if pdfData.images[0] %}
                  <img src="{{ pdfData.images[0].url }}" alt="Page 1">
                  {% assign cover_back_points = pdfData.images[0].points %}
                  {% for point in cover_back_points %}
                    <div
                      data-id="hotspot-0-{{ forloop.index }}"
                      class="custom-hotspot bg-[{{buttonData.hotspotColor}}] points absolute z-[999] top-[{{point.yPercentage}}%] left-[{{point.xPercentage}}%] image-hotspots--pin flex justify-center items-center text-white text-sm h-9 w-9 rounded-full shadow-lg cursor-pointer animate-pulse"
                    >
                      <div class="image-hotspots--pin-button hotspot--pinned active">
                        <svg width="25" height="25" viewBox="0 0 25 25" fill="none">
                          <rect width="25" height="25" rx="12.5" stroke="#F1EFED" stroke-width="9"/>
                          <rect x="4.5" y="4.5" width="16" height="16" rx="8" fill="none" stroke="#F1EFED" stroke-width="9"/>
                        </svg>
                      </div>
                    </div>
                  {% endfor %}
                {% else %}
                  <div class="empty-page"></div>
                {% endif %}
              </div>
            {% endif %}
          </div>

          {% if isWideFormat %}
            {% assign total_spreads = array_length %}

            {% for spread_idx in (1..total_spreads) %}
              {% assign front_img_idx = spread_idx | minus: 1 %}
              {% assign back_img_idx = spread_idx %}

              <div class="page">
                <!-- front = RIGHT half of image[front_img_idx] -->
                {% if front_img_idx < array_length %}
                  <div
                    class="front wide-front relative"
                    style="background-image: url('{{ pdfData.images[front_img_idx].url }}');"
                  >
                    {% assign points = pdfData.images[front_img_idx].points %}
                    {% for point in points %}
                      {% comment %}
                        FIXED: For right pages, show hotspots from the RIGHT half of original image.
                        Map original xPercentage (50-100) → new x (0-100) for this half-page
                      {% endcomment %}
                      {% if point.xPercentage >= 50 %}
                        {% comment %} Map 50-100% to 0-100% for the right half-page {% endcomment %}
                        {% assign adjusted_left = point.xPercentage | minus: 50 | times: 2 %}
                        
                        <div
                          data-id="hotspot-{{front_img_idx}}-{{forloop.index}}"
                          class="custom-hotspot bg-[{{buttonData.hotspotColor}}] points absolute z-[999] top-[{{point.yPercentage}}%] left-[{{adjusted_left}}%] image-hotspots--pin flex justify-center items-center text-white text-sm h-9 w-9 rounded-full shadow-lg cursor-pointer animate-pulse"
                        >
                          <div class="image-hotspots--pin-button hotspot--pinned active">
                            <svg width="25" height="25" viewBox="0 0 25 25" fill="none">
                              <rect width="25" height="25" rx="12.5" stroke="#F1EFED" stroke-width="9"/>
                              <rect x="4.5" y="4.5" width="16" height="16" rx="8" fill="none" stroke="#F1EFED" stroke-width="9"/>
                            </svg>
                          </div>
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                {% else %}
                  <div class="front wide-front"></div>
                {% endif %}

                <!-- back = LEFT half of image[back_img_idx] -->
                {% if back_img_idx < array_length %}
                  <div
                    class="back wide-back relative"
                    style="background-image: url('{{ pdfData.images[back_img_idx].url }}');"
                  >
                    {% assign points = pdfData.images[back_img_idx].points %}
                    {% for point in points %}
                      {% comment %}
                        FIXED: For left pages, show hotspots from the LEFT half of original image.
                        Map original xPercentage (0-50) → new x (0-100) for this half-page
                        No mirroring needed!
                      {% endcomment %}
                      {% if point.xPercentage < 50 %}
                        {% comment %} Map 0-50% to 0-100% for the left half-page {% endcomment %}
                        {% assign adjusted_left = point.xPercentage | times: 2 %}
                        
                        <div
                          data-id="hotspot-{{back_img_idx}}-{{forloop.index}}"
                          class="custom-hotspot bg-[{{buttonData.hotspotColor}}] points absolute z-[999] top-[{{point.yPercentage}}%] left-[{{adjusted_left}}%] image-hotspots--pin flex justify-center items-center text-white text-sm h-9 w-9 rounded-full shadow-lg cursor-pointer animate-pulse"
                        >
                          <div class="image-hotspots--pin-button hotspot--pinned active">
                            <svg width="25" height="25" viewBox="0 0 25 25" fill="none">
                              <rect width="25" height="25" rx="12.5" stroke="#F1EFED" stroke-width="9"/>
                              <rect x="4.5" y="4.5" width="16" height="16" rx="8" fill="none" stroke="#F1EFED" stroke-width="9"/>
                            </svg>
                          </div>
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                {% else %}
                  <div class="back wide-back"></div>
                {% endif %}
              </div>
            {% endfor %}

          {% else %}
            <!-- A4 FORMAT - unchanged, works correctly -->
            {% assign index = 1 %}
            {% assign remaining = array_length | minus: 1 %}
            {% assign total_spreads = remaining | divided_by: 2 | ceil %}

            {% for spread_idx in (1..total_spreads) %}
              {% assign front_img_idx = index %}
              {% assign back_img_idx = index | plus: 1 %}

              <div class="page">
                <div class="front relative">
                  {% if front_img_idx < array_length %}
                    <img src="{{ pdfData.images[front_img_idx].url }}" alt="Page {{ front_img_idx | plus: 1 }}">
                    {% assign points = pdfData.images[front_img_idx].points %}
                    {% for point in points %}
                      <div
                        data-id="hotspot-{{front_img_idx}}-{{forloop.index}}"
                        class="custom-hotspot bg-[{{buttonData.hotspotColor}}] points absolute z-[999] top-[{{point.yPercentage}}%] left-[{{point.xPercentage}}%] image-hotspots--pin flex justify-center items-center text-white text-sm h-9 w-9 rounded-full shadow-lg cursor-pointer animate-pulse"
                      >
                        <div class="image-hotspots--pin-button hotspot--pinned active">
                          <svg width="25" height="25" viewBox="0 0 25 25" fill="none">
                            <rect width="25" height="25" rx="12.5" stroke="#F1EFED" stroke-width="9"/>
                            <rect x="4.5" y="4.5" width="16" height="16" rx="8" fill="none" stroke="#F1EFED" stroke-width="9"/>
                          </svg>
                        </div>
                      </div>
                    {% endfor %}
                  {% else %}
                    <div class="empty-page"></div>
                  {% endif %}
                </div>

                <div class="back">
                  {% if back_img_idx < array_length %}
                    <img src="{{ pdfData.images[back_img_idx].url }}" alt="Page {{ back_img_idx | plus: 1 }}">
                    {% assign points = pdfData.images[back_img_idx].points %}
                    {% for point in points %}
                      <div
                        data-id="hotspot-{{back_img_idx}}-{{forloop.index}}"
                        class="custom-hotspot bg-[{{buttonData.hotspotColor}}] points absolute z-[999] top-[{{point.yPercentage}}%] left-[{{point.xPercentage}}%] image-hotspots--pin flex justify-center items-center text-white text-sm h-9 w-9 rounded-full shadow-lg cursor-pointer animate-pulse"
                      >
                        <div class="image-hotspots--pin-button hotspot--pinned active">
                          <svg width="25" height="25" viewBox="0 0 25 25" fill="none">
                            <rect width="25" height="25" rx="12.5" stroke="#F1EFED" stroke-width="9"/>
                            <rect x="4.5" y="4.5" width="16" height="16" rx="8" fill="none" stroke="#F1EFED" stroke-width="9"/>
                          </svg>
                        </div>
                      </div>
                    {% endfor %}
                  {% else %}
                    <div class="empty-page"></div>
                  {% endif %}
                </div>
              </div>

              {% assign index = back_img_idx | plus: 1 %}
            {% endfor %}
          {% endif %}
        </div>

        <!-- Navigation Buttons -->
        <button class="book-prev-next prev">
          <div class="flex items-center gap-1 bg-white/90 backdrop-blur px-5 py-3 rounded-full shadow-xl">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path d="M14.071 5L7.70708 11.364C7.31656 11.7545 7.31656 12.3877 7.70708 12.7782L14.071 19.1421" stroke="#000000" stroke-linecap="round"></path> </g>
            </svg>
          </div>
        </button>

        <button class="book-prev-next next">
          <div class="flex items-center gap-1 bg-white/90 backdrop-blur px-5 py-3 rounded-full shadow-xl">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path d="M9.92896 4.85785L16.2929 11.2218C16.6834 11.6123 16.6834 12.2455 16.2929 12.636L9.92896 19" stroke="#000000" stroke-linecap="round"></path> </g>
            </svg>
          </div>
        </button>
      </div>

      <!-- Thumbnail Navigation -->
      <div class="thumbnail-nav">
        <div class="thumbnail-track">
          <div class="thumbnail-item" data-spread="0">
            <div class="thumbnail-img-wrapper {% unless pdfData.coverImage %}cover-thumb{% endunless %}">
              {% if pdfData.coverImage %}
                <img src="{{ pdfData.coverImage }}" alt="{{ pdfData.pdfName }}" class="thumbnail-img">
              {% else %}
                <span>{{ pdfData.pdfName | truncate: 10, '' }}</span>
              {% endif %}
            </div>
            <span class="thumbnail-label">Cover</span>
          </div>

          {% if isWideFormat %}
            {% for s in (0..array_length) %}
              {% assign thumb_spread = s | plus: 1 %}
              {% if s < array_length %}
                <div class="thumbnail-item" data-spread="{{ thumb_spread }}">
                  <div class="thumbnail-img-wrapper">
                    <img src="{{ pdfData.images[s].url }}" alt="Page {{ s | plus: 1 }}" class="thumbnail-img">
                  </div>
                  <span class="thumbnail-label">{{ s | plus: 1 }}</span>
                </div>
              {% endif %}
            {% endfor %}
          {% else %}
            {% assign thumb_spread = 1 %}
            {% assign thumb_img_idx = 1 %}
            {% assign remaining = array_length | minus: 1 %}
            {% assign thumb_total = remaining | divided_by: 2 | ceil %}

            {% for s in (1..thumb_total) %}
              {% assign front_num = thumb_img_idx %}
              {% assign back_num = thumb_img_idx | plus: 1 %}

              <div class="thumbnail-item" data-spread="{{ thumb_spread }}">
                <div class="thumbnail-img-wrapper">
                  <img
                    src="{{ pdfData.images[front_num].url }}"
                    alt="Pages {{ front_num | plus: 1 }}-{{ back_num | plus: 1 }}"
                    class="thumbnail-img"
                  >
                </div>
                <span class="thumbnail-label">{{ front_num | plus: 1 }}-{{ back_num | plus: 1 }}</span>
              </div>

              {% assign thumb_spread = thumb_spread | plus: 1 %}
              {% assign thumb_img_idx = thumb_img_idx | plus: 2 %}
            {% endfor %}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% comment %} Mobile Book Viewer {% endcomment %}
<div class="mobile-book-viewer">
  <button class="mobile-book-nav prev" aria-label="Previous page">
    <span>
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path d="M14.071 5L7.70708 11.364C7.31656 11.7545 7.31656 12.3877 7.70708 12.7782L14.071 19.1421" stroke="#000000" stroke-linecap="round"></path> </g>
      </svg>
    </span>
  </button>

  <div class="mobile-book-stage">
    <div class="mobile-book-track">
      {% if pdfData.coverImage %}
        <div class="mobile-book-page active" data-page-index="0">
          <img src="{{ pdfData.coverImage }}" alt="{{ pdfData.pdfName }}">
        </div>
      {% else %}
        <div class="mobile-book-page active cover-page" data-page-index="0">
          <div class="cover-title-wrap">
            <span class="cover-title">{{ pdfData.pdfName }}</span>
          </div>
        </div>
      {% endif %}

      {% for image in pdfData.images %}
        {% assign mobile_page_index = forloop.index %}
        <div class="mobile-book-page" data-page-index="{{ mobile_page_index }}">
          <img src="{{ image.url }}" alt="Page {{ mobile_page_index }}">
          {% assign points = image.points %}
          {% for point in points %}
            <div
              data-id="mobile-hotspot-{{ mobile_page_index }}-{{ forloop.index }}"
              class="custom-hotspot mobile-points absolute z-[999] top-[{{ point.yPercentage }}%] left-[{{ point.xPercentage }}%] image-hotspots--pin flex justify-center items-center text-white text-sm h-9 w-9 rounded-full shadow-lg cursor-pointer animate-pulse"
            >
              <div class="image-hotspots--pin-button hotspot--pinned active">
                <svg width="25" height="25" viewBox="0 0 25 25" fill="none">
                  <rect width="25" height="25" rx="12.5" stroke="#F1EFED" stroke-width="9"/>
                  <rect x="4.5" y="4.5" width="16" height="16" rx="8" fill="none" stroke="#F1EFED" stroke-width="9"/>
                </svg>
              </div>
            </div>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>

  <button class="mobile-book-nav next" aria-label="Next page">
    <span>
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path d="M9.92896 4.85785L16.2929 11.2218C16.6834 11.6123 16.6834 12.2455 16.2929 12.636L9.92896 19" stroke="#000000" stroke-linecap="round"></path> </g>
      </svg>
    </span>
  </button>
</div>

<script src="{{ 'main.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "PDF-CONVERTER",
  "class": "section",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "metafield_key",
      "label": "PDF KEY",
      "default": "PDF KEY"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "padding bottom",
      "default": 36
    }
  ]
}
{% endschema %}