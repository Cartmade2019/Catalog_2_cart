{% assign product = all_products[handle] %}

<div data-hotspot-id="hotspot-{{data_page_index}}-{{data_hotspot_index}}"
  class="custom-popover hidden fixed z-[9999] w-[300px] rounded-[16px] overflow-hidden shadow-2xl"
  style="background: {{tooltipData.backgroundColor}}; color: {{tooltipData.fontColor}};">

  <!-- Close button -->
  <button type="button"
    class="cross-btn absolute right-3 top-3 z-20 inline-flex h-7 w-7 items-center justify-center rounded-full bg-white/80 text-black shadow-md transition hover:bg-white"
    aria-label="Close">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
      <path d="M19 5L5 19M5 5L19 19" stroke="#555" stroke-width="2.5"
        stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <!-- Image: full-width top -->
  <div class="w-full h-[180px] overflow-hidden bg-[#f4f5f7]">
    {% if product.featured_image %}
      <img src="{{ product.featured_image | img_url: 'medium' }}" alt="{{ product.title }}"
        class="w-full h-full object-contain block">
    {% else %}
      <img src="https://cdn.shopify.com/s/files/1/0262/4071/2726/files/emptystate-files.png" alt="{{ product.title }}"
        class="w-full h-full object-contain block">
    {% endif %}
  </div>

  <!-- Content: below image -->
  <div class="flex flex-col px-4 pt-3 pb-4 gap-0">
    {% if product %}

      <!-- Title -->
      <h3 class="font-bold text-[16px] leading-snug mb-1 pr-4" style="color: {{tooltipData.fontColor}};">
        {{ product.title }}
      </h3>

      {% if product.description %}
        <p class="text-[12px] leading-5 opacity-70 mb-1">
          {{ product.description | strip_html | truncatewords: 10 }}
        </p>
      {% endif %}

      <!-- Price -->
      <p class="text-[13px] font-semibold mb-1" style="color: {{tooltipData.priceColor}};">
        <span class="opacity-70">Price:</span> {{ product.price | money }}
      </p>

      <!-- Variant select -->
      {% if product.variants.size > 1 %}
        <select
          name="id"
          class="pointer-events-auto cursor-pointer mt-1 mb-2 w-full rounded-lg border border-black/10 bg-white/80 px-3 py-2 text-[13px] outline-none focus:border-black/20 focus:bg-white">
          {% for variant in product.variants %}
            <option value="{{ variant.id }}">{{ variant.title }}</option>
          {% endfor %}
        </select>
      {% else %}
        <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      {% endif %}

      <!-- Loading UI -->
      <div class="tooltip-loading hidden mt-3">
        <div class="mb-2 flex items-center gap-2">
          <span class="loading-spinner inline-flex h-4 w-4">
            <svg class="h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-opacity="0.2" stroke-width="3"></circle>
              <path d="M22 12a10 10 0 0 0-10-10" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
            </svg>
          </span>
          <span class="loading-success hidden h-4 w-4">
            <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4">
              <path d="M6 6L18 18M18 6L6 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </span>
          <span class="loading-text text-[11px] font-semibold uppercase tracking-[0.18em] opacity-70">Adding to cart</span>
          <span class="loading-percent ml-auto text-[11px] font-semibold opacity-70">0%</span>
        </div>
        <div class="h-2 w-full overflow-hidden rounded-full bg-black/10">
          <div class="loading-bar h-full w-0 rounded-full bg-black/80 transition-all duration-300 ease-out"></div>
        </div>
      </div>

      <!-- Buttons: equal width, side by side -->
      <div class="flex items-stretch gap-2 mt-3">
        {% comment %} box-shadow: 2px 2px {{buttonData.shadow}}px {{buttonData.shadowColor}}; border: {{buttonData.borderWidth}}px solid {{buttonData.borderColor}}; {% endcomment %}
        <button
          type="button"
          style="background-color: {{buttonData.backgroundColor}}; color: {{buttonData.textColor}}; padding: {{buttonData.paddingY}}px {{buttonData.paddingX}}px; border-radius: {{buttonData.borderRadius}}px; font-size: {{buttonData.fontSize}}px;"
          class="add-to-cart-btn pointer-events-auto cursor-pointer flex-1 transition inline-flex items-center justify-center gap-2  disabled:cursor-not-allowed disabled:opacity-60">
          <span class="btn-text">{{ buttonData.buttonText }}</span>
        </button>

        <a
          style="background-color: #606060; color: #ffffff; padding: {{buttonData.paddingY}}px {{buttonData.paddingX}}px; border-radius: {{buttonData.borderRadius}}px; font-size: {{buttonData.fontSize}}px;"
          href="/products/{{product.handle}}" target="_blank"
          class="view-product-btn flex-1 inline-flex items-center justify-center gap-1  transition hover:opacity-90">
          View Product
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 17L17 7M17 7H7M17 7V17"/>
          </svg>
        </a>
      </div>

    {% else %}
      <p class="text-[13px] opacity-50">Product not found.</p>
    {% endif %}
  </div>

</div>