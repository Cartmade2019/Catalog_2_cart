{% assign product = all_products[handle] %}

<div data-hotspot-id="hotspot-{{data_page_index}}-{{data_hotspot_index}}"
    class="custom-popover hidden">
  <div class="relative rounded-[20px] overflow-hidden" style="background: {{tooltipData.backgroundColor}}; color: {{tooltipData.fontColor}};">

    <button type="button" class="cross-btn" aria-label="Close">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
        <path d="M19 5L5 19M5 5L19 19" stroke="#555" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="modal-content-wrapper">

      <!-- Left: fixed image panel -->
      <div class="modal-content-item">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | img_url: 'medium' }}" alt="{{ product.title }}">
        {% else %}
          <img src="https://cdn.shopify.com/s/files/1/0262/4071/2726/files/emptystate-files.png" alt="{{ product.title }}">
        {% endif %}
      </div>

      <!-- Right: content panel -->
      <div class="modal-content-item">
        {% if product %}
          <h3 style="color: {{tooltipData.fontColor}};">{{ product.title }}</h3>
          <p class="desc">{{ product.description | strip_html | truncatewords: 10 }}</p>
          <p class="font-bold" style="color: {{tooltipData.priceColor}};">{{ product.price | money }}</p>

          {% if product.variants.size > 1 %}
            <select name="id" class="pointer-events-auto cursor-pointer">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}">{{ variant.title }}</option>
              {% endfor %}
            </select>
          {% else %}
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
          {% endif %}

          <button type="button"
            style="box-shadow: 2px 2px {{buttonData.shadow}}px {{buttonData.shadowColor}}; border: {{buttonData.borderWidth}}px solid {{buttonData.borderColor}}; background-color: {{buttonData.backgroundColor}}; color: {{buttonData.textColor}}; padding: {{buttonData.paddingY}}px {{buttonData.paddingX}}px; border-radius: {{buttonData.borderRadius}}; font-size: {{buttonData.fontSize}}px;"
            class="add-to-cart-btn pointer-events-auto cursor-pointer w-full transition">
            {{ buttonData.buttonText }}
          </button>

          <a href="/products/{{product.handle}}" target="_blank" class="view-product-btn">
            View product
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7M17 7H7M17 7V17"/>
            </svg>
          </a>

        {% else %}
          <p style="font-size:0.85rem; opacity:0.5;">Product not found.</p>
        {% endif %}
      </div>

    </div>
  </div>
</div>
