{% assign product = all_products[handle] %}

<div data-hotspot-id="hotspot-{{data_page_index}}-{{data_hotspot_index}}"
    class="custom-popover hidden">
    <div class="relative bg-[{{tooltipData.backgroundColor}}] text-[{{tooltipData.fontColor}}] rounded-[10px] overflow-hidden">

        <button type="button" class="cross-btn" aria-label="Close">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 5L4.99998 19M5.00001 5L19 19" stroke="#555" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>

        <div class="modal-content-wrapper">
            <div class="modal-content-item">
                {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: 'medium' }}" alt="{{ product.title }}">
                {% else %}
                <img src="https://cdn.shopify.com/s/files/1/0262/4071/2726/files/emptystate-files.png" alt="{{ product.title }}">
                {% endif %}
            </div>

            <div class="modal-content-item">
                {% if product %}
                <h3 class="text-xl font-semibold" style="color: {{tooltipData.fontColor}};">{{ product.title }}</h3>
                <p class="text-sm mt-1 desc">{{ product.description | truncatewords: 12 }}</p>
                <p class="text-base font-bold mt-2" style="color: {{tooltipData.priceColor}};">{{ product.price | money }}</p>

                <div class="mt-4" id="add-to-cart-form-{{ data_page_index }}-{{ data_hotspot_index }}">
                    {% if product.variants.size > 1 %}
                    <select name="id"
                        class="w-full p-2 border rounded mt-2 text-black pointer-events-auto cursor-pointer">
                        {% for variant in product.variants %}
                        <option value="{{ variant.id }}">{{ variant.title }}</option>
                        {% endfor %}
                    </select>
                    {% else %}
                    <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                    {% endif %}

                    <button type="button"
                        style="box-shadow: 2px 2px {{buttonData.shadow}}px {{buttonData.shadowColor}}; border: {{buttonData.borderWidth}}px solid {{buttonData.borderColor}}; background-color: {{buttonData.backgroundColor}}; color: {{buttonData.textColor}}; padding: {{buttonData.paddingY}}px {{buttonData.paddingX}}px; border-radius: {{buttonData.borderRadius}}; font-size: {{buttonData.fontSize}}px;"
                        class="add-to-cart-btn pointer-events-auto cursor-pointer w-full transition mt-3">
                        {{ buttonData.buttonText }}
                    </button>

                    <a href="/products/{{product.handle}}" target="_blank"
                        class="block text-center mt-2 text-sm text-blue-600 underline hover:text-blue-800">
                        View product
                    </a>
                </div>
                {% else %}
                <p class="text-sm text-gray-500">Product not found.</p>
                {% endif %}
            </div>
        </div>

    </div>
</div>